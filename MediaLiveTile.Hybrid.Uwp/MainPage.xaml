<Page
    x:Class="MediaLiveTile.Hybrid.Uwp.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:model="using:MediaLiveTile.Hybrid.Uwp.Models"
    xmlns:sharedmodel="using:MediaLiveTile.Hybrid.Shared.Models"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid Background="{ThemeResource ApplicationPageBackgroundThemeBrush}" Padding="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 顶部标题 -->
        <StackPanel>
            <TextBlock Text="MediaLiveTile.Hybrid"
                       FontSize="42"/>
            <TextBlock Text="UWP Shell"
                       Margin="0,4,0,24"
                       Opacity="0.7"/>
        </StackPanel>

        <!-- 主体三栏 -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="760"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="220"/>
            </Grid.ColumnDefinitions>

            <!-- 左栏：预览 -->
            <ScrollViewer Grid.Column="0"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Margin="0,0,24,0">
                <StackPanel>
                    <TextBlock Text="预览"
                               FontSize="28"
                               FontWeight="SemiBold"/>

                    <!-- 小磁贴 -->
                    <StackPanel Orientation="Horizontal" Margin="0,24,0,8">
                        <TextBlock Text="小磁贴"
                                   VerticalAlignment="Center"/>
                        <Button x:Name="PinSmallTileButton"
        Content="固定磁贴"
        Click="PinSmallTileButton_Click"
        Margin="12,0,0,0"
        MinWidth="96"/>
                    </StackPanel>

                    <Border Width="71"
                            Height="71"
                            Background="{ThemeResource SystemControlBackgroundChromeMediumLowBrush}">
                        <Grid>
                            <Image x:Name="SmallPreviewImage"
                                   Stretch="UniformToFill"/>
                        </Grid>
                    </Border>

                    <!-- 中磁贴 -->
                    <StackPanel Orientation="Horizontal" Margin="0,24,0,8">
                        <TextBlock Text="中磁贴（封面 / 信息）"
                                   VerticalAlignment="Center"/>
                        <Button x:Name="PinMediumTileButton"
        Content="固定磁贴"
        Click="PinMediumTileButton_Click"
        Margin="12,0,0,0"
        MinWidth="96"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal">
                        <Border Width="150"
                                Height="150"
                                Background="{ThemeResource SystemControlBackgroundChromeMediumLowBrush}">
                            <Grid>
                                <Image x:Name="MediumCoverPreviewImage"
                                       Stretch="UniformToFill"/>
                            </Grid>
                        </Border>

                        <Border Width="150"
                                Height="150"
                                Margin="12,0,0,0"
                                Padding="12"
                                Background="{ThemeResource SystemControlBackgroundChromeMediumLowBrush}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock x:Name="MediumInfoTitleText"
                                           FontSize="16"
                                           FontWeight="SemiBold"
                                           Foreground="{ThemeResource SystemControlForegroundBaseHighBrush}"
                                           TextAlignment="Left"
                                           HorizontalAlignment="Stretch"
                                           VerticalAlignment="Top"
                                           MaxLines="2"
                                           TextWrapping="WrapWholeWords"
                                           TextTrimming="CharacterEllipsis"/>

                                <TextBlock x:Name="MediumInfoArtistText"
                                           Grid.Row="1"
                                           Margin="0,8,0,0"
                                           Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                                           TextAlignment="Left"
                                           HorizontalAlignment="Stretch"
                                           MaxLines="2"
                                           TextWrapping="WrapWholeWords"
                                           TextTrimming="CharacterEllipsis"/>

                                <TextBlock x:Name="MediumInfoSourceText"
                                           Grid.Row="2"
                                           Margin="0,8,0,0"
                                           Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                                           TextAlignment="Left"
                                           HorizontalAlignment="Stretch"
                                           MaxLines="1"
                                           TextTrimming="CharacterEllipsis"/>
                            </Grid>
                        </Border>
                    </StackPanel>

                    <!-- 宽磁贴 -->
                    <StackPanel Orientation="Horizontal" Margin="0,24,0,8">
                        <TextBlock Text="宽磁贴"
                                   VerticalAlignment="Center"/>
                        <Button x:Name="PinWideTileButton"
        Content="固定磁贴"
        Click="PinWideTileButton_Click"
        Margin="12,0,0,0"
        MinWidth="96"/>
                    </StackPanel>

                    <Border Width="310"
                            Height="150"
                            Background="{ThemeResource SystemControlBackgroundChromeMediumLowBrush}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0"
                                    Width="150"
                                    Height="150"
                                    Background="{ThemeResource SystemControlBackgroundChromeMediumLowBrush}">
                                <Image x:Name="WidePreviewImage"
                                       Stretch="UniformToFill"/>
                            </Border>

                            <Grid Grid.Column="1" Margin="12,12,12,12">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock x:Name="WideTitleText"
                                           FontSize="18"
                                           FontWeight="SemiBold"
                                           Foreground="{ThemeResource SystemControlForegroundBaseHighBrush}"
                                           TextAlignment="Left"
                                           HorizontalAlignment="Stretch"
                                           VerticalAlignment="Top"
                                           MaxLines="2"
                                           TextWrapping="WrapWholeWords"
                                           TextTrimming="CharacterEllipsis"/>

                                <TextBlock x:Name="WideArtistText"
                                           Grid.Row="1"
                                           Margin="0,8,0,0"
                                           Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                                           TextAlignment="Left"
                                           HorizontalAlignment="Stretch"
                                           MaxLines="2"
                                           TextWrapping="WrapWholeWords"
                                           TextTrimming="CharacterEllipsis"/>

                                <TextBlock x:Name="WideSourceText"
                                           Grid.Row="2"
                                           Margin="0,8,0,0"
                                           Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                                           TextAlignment="Left"
                                           HorizontalAlignment="Stretch"
                                           MaxLines="1"
                                           TextTrimming="CharacterEllipsis"/>
                            </Grid>
                        </Grid>
                    </Border>

                    <!-- 大磁贴 -->
                    <StackPanel Orientation="Horizontal" Margin="0,24,0,8">
                        <TextBlock Text="大磁贴（封面 / 信息）"
                                   VerticalAlignment="Center"/>
                        <Button x:Name="PinLargeTileButton"
        Content="固定磁贴"
        Click="PinLargeTileButton_Click"
        Margin="12,0,0,0"
        MinWidth="96"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal">
                        <Border Width="310"
                                Height="310"
                                Background="{ThemeResource SystemControlBackgroundChromeMediumLowBrush}">
                            <Grid>
                                <Image x:Name="LargeCoverPreviewImage"
                                       Stretch="UniformToFill"/>
                            </Grid>
                        </Border>

                        <Border Width="310"
                                Height="310"
                                Margin="12,0,0,0"
                                Padding="18"
                                Background="{ThemeResource SystemControlBackgroundChromeMediumLowBrush}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock x:Name="LargeInfoTitleText"
                                           FontSize="24"
                                           FontWeight="SemiBold"
                                           Foreground="{ThemeResource SystemControlForegroundBaseHighBrush}"
                                           TextAlignment="Left"
                                           HorizontalAlignment="Stretch"
                                           VerticalAlignment="Top"
                                           MaxLines="3"
                                           TextWrapping="WrapWholeWords"
                                           TextTrimming="CharacterEllipsis"/>

                                <TextBlock x:Name="LargeInfoArtistText"
                                           Grid.Row="1"
                                           Margin="0,12,0,0"
                                           Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                                           TextAlignment="Left"
                                           HorizontalAlignment="Stretch"
                                           MaxLines="2"
                                           TextWrapping="WrapWholeWords"
                                           TextTrimming="CharacterEllipsis"/>

                                <TextBlock x:Name="LargeInfoSourceText"
                                           Grid.Row="2"
                                           Margin="0,12,0,0"
                                           Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                                           TextAlignment="Left"
                                           HorizontalAlignment="Stretch"
                                           MaxLines="1"
                                           TextTrimming="CharacterEllipsis"/>
                            </Grid>
                        </Border>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>

            <!-- 中栏：控制 / 状态 / 会话 -->
            <ScrollViewer Grid.Column="1"
                          VerticalScrollBarVisibility="Auto"
                          Margin="0,0,24,0">
                <StackPanel>
                    <TextBlock Text="控制 / 监测"
                               FontSize="28"
                               FontWeight="SemiBold"/>

                    <TextBlock Text="磁贴显示目标"
                               FontSize="20"
                               FontWeight="SemiBold"
                               Margin="0,20,0,12"/>

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="140"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="小磁贴"
                                   VerticalAlignment="Center"/>
                        <ComboBox x:Name="SmallTargetComboBox"
                                  Grid.Column="1"
                                  Width="120"
                                  ItemsSource="{x:Bind TargetOptions, Mode=OneWay}"
                                  DisplayMemberPath="DisplayText"
                                  SelectionChanged="SmallTargetComboBox_SelectionChanged"/>

                        <TextBlock Grid.Row="1"
                                   Text="中磁贴"
                                   Margin="0,8,0,0"
                                   VerticalAlignment="Center"/>
                        <ComboBox x:Name="MediumTargetComboBox"
                                  Grid.Row="1"
                                  Grid.Column="1"
                                  Margin="0,8,0,0"
                                  Width="120"
                                  ItemsSource="{x:Bind TargetOptions, Mode=OneWay}"
                                  DisplayMemberPath="DisplayText"
                                  SelectionChanged="MediumTargetComboBox_SelectionChanged"/>

                        <TextBlock Grid.Row="2"
                                   Text="宽磁贴"
                                   Margin="0,8,0,0"
                                   VerticalAlignment="Center"/>
                        <ComboBox x:Name="WideTargetComboBox"
                                  Grid.Row="2"
                                  Grid.Column="1"
                                  Margin="0,8,0,0"
                                  Width="120"
                                  ItemsSource="{x:Bind TargetOptions, Mode=OneWay}"
                                  DisplayMemberPath="DisplayText"
                                  SelectionChanged="WideTargetComboBox_SelectionChanged"/>

                        <TextBlock Grid.Row="3"
                                   Text="大磁贴"
                                   Margin="0,8,0,0"
                                   VerticalAlignment="Center"/>
                        <ComboBox x:Name="LargeTargetComboBox"
                                  Grid.Row="3"
                                  Grid.Column="1"
                                  Margin="0,8,0,0"
                                  Width="120"
                                  ItemsSource="{x:Bind TargetOptions, Mode=OneWay}"
                                  DisplayMemberPath="DisplayText"
                                  SelectionChanged="LargeTargetComboBox_SelectionChanged"/>
                    </Grid>

                    <StackPanel Orientation="Horizontal" Margin="0,20,0,0">
                        <ToggleSwitch x:Name="MonitoringToggleSwitch"
                                      Header="启用媒体监测"
                                      Toggled="MonitoringToggleSwitch_Toggled"/>

                        <Button Content="立即刷新"
                                Click="RefreshNowButton_Click"
                                Margin="20,28,0,0"
                                Height="40"/>
                    </StackPanel>

                    <TextBlock x:Name="MonitoringStateTextBlock"
                               Margin="0,16,0,0"
                               Text="状态：读取中..."/>

                    <TextBlock x:Name="MonitoringHintTextBlock"
                               Margin="0,4,0,0"
                               Opacity="0.8"
                               TextWrapping="WrapWholeWords"/>

                    <TextBlock Text="开机自启"
                               FontSize="20"
                               FontWeight="SemiBold"
                               Margin="0,24,0,12"/>

                    <ToggleSwitch x:Name="StartupToggleSwitch"
                                  Header="启用托盘开机自启"
                                  Toggled="StartupToggleSwitch_Toggled"/>

                    <TextBlock x:Name="StartupStateTextBlock"
                               Margin="0,12,0,0"
                               Text="状态：读取中..."/>

                    <TextBlock x:Name="StartupHintTextBlock"
                               Margin="0,4,0,0"
                               Opacity="0.8"
                               TextWrapping="WrapWholeWords"/>

                    <TextBlock Text="Tray 当前状态"
                               FontSize="20"
                               FontWeight="SemiBold"
                               Margin="0,24,0,12"/>

                    <TextBlock x:Name="TrayStatusTextBlock"
                               Text="状态：读取中..."/>
                    <TextBlock x:Name="TrayLastRefreshTextBlock"
                               Margin="0,4,0,0"
                               Text="上次刷新：--"/>
                    <TextBlock x:Name="PrimaryMediaTextBlock"
                               Margin="0,8,0,0"
                               Text="主媒体：无"
                               TextWrapping="WrapWholeWords"/>
                    <TextBlock x:Name="SecondaryMediaTextBlock"
                               Margin="0,4,0,0"
                               Text="次媒体：无"
                               TextWrapping="WrapWholeWords"/>

                    <TextBlock Text="媒体会话"
                               FontSize="20"
                               FontWeight="SemiBold"
                               Margin="0,24,0,12"/>

                    <ItemsControl ItemsSource="{x:Bind Sessions, Mode=OneWay}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="sharedmodel:SharedStateSessionItem">
                                <Border Background="{ThemeResource SystemControlBackgroundChromeMediumLowBrush}"
                                        Padding="8"
                                        Margin="0,0,0,8">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="52"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <Border Width="52"
                                                Height="52"
                                                Background="{ThemeResource SystemControlBackgroundChromeMediumLowBrush}">
                                            <Image Source="{x:Bind ImageUri, Mode=OneWay}"
                                                   Stretch="UniformToFill"/>
                                        </Border>

                                        <StackPanel Grid.Column="1" Margin="12,0,0,0">
                                            <TextBlock Text="{x:Bind SourceDisplayName}"
                                                       FontWeight="SemiBold"
                                                       TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Text="{x:Bind Role}"
                                                       Opacity="0.8"/>
                                            <TextBlock Text="{x:Bind Title}"
                                                       MaxLines="1"
                                                       TextTrimming="CharacterEllipsis"
                                                       Opacity="0.9"/>
                                            <TextBlock Text="{x:Bind PlaybackStatus}"
                                                       Opacity="0.7"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </ScrollViewer>

            <!-- 右栏：操作 -->
            <StackPanel Grid.Column="2">
                <TextBlock Text="操作"
                           FontSize="28"
                           FontWeight="SemiBold"/>

                <Button Content="打开日志"
                        Click="OpenLogButton_Click"
                        Height="48"
                        Margin="0,24,0,12"/>

                <Button Content="关于此应用"
                        Click="AboutAppButton_Click"
                        Height="48"/>

                <TextBlock x:Name="ActionStatusTextBlock"
                           Margin="0,16,0,0"
                           Opacity="0.8"
                           TextWrapping="WrapWholeWords"/>
            </StackPanel>
        </Grid>
    </Grid>
</Page>