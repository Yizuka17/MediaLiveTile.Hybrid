<Page
    x:Class="MediaLiveTile.Hybrid.Uwp.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Background="{ThemeResource ApplicationPageBackgroundThemeBrush}" Padding="32">
        <StackPanel Spacing="16">
            <TextBlock Text="MediaLiveTile.Hybrid"
                       FontSize="40" />

            <TextBlock Text="UWP Shell 最小验证页"
                       FontSize="18"
                       Opacity="0.8"/>

            <Border Background="{ThemeResource SystemControlBackgroundChromeMediumLowBrush}"
                    Padding="16">
                <StackPanel Spacing="8">
                    <TextBlock Text="当前状态"
                               FontSize="20"
                               FontWeight="SemiBold"/>
                    <TextBlock x:Name="StatusTextBlock"
                               Text="等待激活信息..."
                               TextWrapping="WrapWholeWords"/>
                </StackPanel>
            </Border>

            <StackPanel Orientation="Horizontal" Spacing="12">
                <Button Content="测试协议唤起自身"
                        Click="TestProtocolButton_Click"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Page>